# Taskfile deployment variables — copy this to .env and fill in your values.
# .env is gitignored; .env.example is committed.

# Container registry prefix for kio-api and kio-ui images.
# Examples: ghcr.io/your-org   harbor.your-domain.com/your-org
HARBOR=your-registry.example.com/your-org

# Git remote used by _kio:install to clone/update the repo on Pi nodes.
KIO_REPO=git@github.com:your-org/kio.git

# Path on each Pi node where the repo lives.
KIO_DIR=/home/pi/kio

# MQTT broker IP for `task mqtt:monitor`.
MQTT_HOST=192.168.1.100
