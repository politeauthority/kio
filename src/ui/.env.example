# OIDC auth — if both vars are set, the UI will require login via Authentik.
# Leave blank for local dev (auth disabled when API_DISABLED=true on the server).
#
# In Authentik: create an Application with an OAuth2/OpenID Connect provider.
#   Client type: Public (no secret needed for PKCE flows)
#   Redirect URI: https://kio.example.com/callback
#   Scopes: openid profile email
#
VITE_OIDC_AUTHORITY=
VITE_OIDC_CLIENT_ID=

# Show the Feature Flags settings page. Set to "True" to enable.
# VITE_SHOW_FEATURE_FLAGS is used by the Vite dev server (npm run dev).
# SHOW_FEATURE_FLAGS is injected at container startup by docker-entrypoint.sh.
VITE_SHOW_FEATURE_FLAGS=True
