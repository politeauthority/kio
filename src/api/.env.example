# Local dev — points at q-postgres (192.168.50.89) with kio_dev database.
# Get password: kubectl get secret -n q-postgres kio-dev-postgres-user -o jsonpath='{.data.password}' | base64 -d
DATABASE_URL=postgresql+asyncpg://kio_dev:CHANGE_ME@localhost:5432/kio_dev
MQTT_HOST=192.168.50.86
MQTT_PORT=1883

# Auth — set AUTH_DISABLED=true for local dev to skip all dashboard auth checks.
# In production: set AUTHENTIK_ISSUER and remove AUTH_DISABLED.
AUTH_DISABLED=true
# Authentik OIDC issuer URL (Applications > Your App > OpenID Connect > Issuer URL)
# e.g. https://auth.example.com/application/o/kio/
AUTHENTIK_ISSUER=
# Comma-separated static API keys for HACS / scripts (e.g. kio_abc123,kio_def456)
API_KEYS=
