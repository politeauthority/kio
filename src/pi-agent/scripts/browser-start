#!/bin/bash

START_URL=$(python3 -c "
with open('/etc/kio/kiosk.yaml') as f:
    for line in f:
        s = line.strip()
        if s.startswith('start_url:'):
            print(s.split(':', 1)[1].strip())
            break
" 2>/dev/null)

# Core flags — always on
CORE_FLAGS=(
  # Force the Wayland backend. The kiosk runs a Wayland-only labwc session with no
  # X server; without this, Chromium 148+ defaults to the X11 ozone backend, fails
  # with "Missing X server or $DISPLAY", and exits immediately on launch.
  --ozone-platform=wayland
  --password-store=basic
  --kiosk
  --remote-debugging-port=9222
  --remote-allow-origins=http://localhost:9222
  --hide-crash-restore-bubble
  --hide-scrollbars
)

# Optional flags — managed via kio dashboard, written by the agent on startup
FLAGS_FILE="/etc/kio/browser-flags"
OPTIONAL_FLAGS=()
if [ -f "$FLAGS_FILE" ]; then
  while IFS= read -r flag; do
    [[ -n "$flag" ]] && OPTIONAL_FLAGS+=("$flag")
  done < "$FLAGS_FILE"
fi

# Chromium 100+ requires WebContentsForceDark to actually invert web content;
# --force-dark-mode alone only affects the browser UI chrome.
if printf '%s\n' "${OPTIONAL_FLAGS[@]}" | grep -qx -- '--force-dark-mode'; then
  if ! printf '%s\n' "${OPTIONAL_FLAGS[@]}" | grep -q 'WebContentsForceDark'; then
    OPTIONAL_FLAGS+=('--enable-features=WebContentsForceDark')
  fi
fi

# Deduplicate: drop optional flags already covered by core flags
CORE_STR="${CORE_FLAGS[*]}"
DEDUPED=()
for flag in "${OPTIONAL_FLAGS[@]}"; do
  [[ " $CORE_STR " == *" $flag "* ]] || DEDUPED+=("$flag")
done
OPTIONAL_FLAGS=("${DEDUPED[@]}")

chromium "${CORE_FLAGS[@]}" "${OPTIONAL_FLAGS[@]}" "${START_URL}" > /dev/null 2>&1 &
