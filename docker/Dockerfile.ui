# syntax=docker/dockerfile:1

# Multi-stage build for the kio UI.
#   build       -> compile the Vue/Vite bundle with the full toolchain
#   production  -> serve the static bundle from rootless nginx (default target)
#
# The runtime is nginxinc/nginx-unprivileged: master + workers run as uid 101,
# listen on :8080, and write only to /tmp — so the pod can run with
# runAsNonRoot + drop ALL caps (see kubernetes-manifests/base/ui).

ARG NODE_VERSION=22-alpine
ARG NGINX_VERSION=1.27-alpine

############################################################
# build — produce /app/dist
############################################################
FROM node:${NODE_VERSION} AS build
WORKDIR /app
ENV CI=true

# Lockfile-pinned, reproducible install (cached until deps change).
COPY src/ui/package.json src/ui/package-lock.json ./
RUN npm ci --no-audit --no-fund

COPY src/ui/ .
RUN node node_modules/vite/bin/vite.js build

############################################################
# production — rootless nginx serving the static bundle
############################################################
FROM nginxinc/nginx-unprivileged:${NGINX_VERSION} AS production

ARG KIO_BRANCH=
ENV KIO_BRANCH=$KIO_BRANCH

# The entrypoint rewrites placeholders in index.html at startup, so both the
# files AND their directory must be writable by the runtime user (uid 101) —
# `sed -i` creates a temp file inside the directory.
USER root
COPY --chown=101:101 --from=build /app/dist /usr/share/nginx/html
RUN chown 101:101 /usr/share/nginx/html
COPY src/ui/nginx.conf /etc/nginx/conf.d/default.conf
COPY --chown=101:101 --chmod=0755 src/ui/docker-entrypoint.sh /docker-entrypoint.sh
USER 101

EXPOSE 8080
ENTRYPOINT ["/docker-entrypoint.sh"]
CMD ["nginx", "-g", "daemon off;"]
