# Copy to .env and fill in the kio_dev password from the k8s secret.
#
# Get it with:
#   kubectl get secret -n q-postgres kio-dev-postgres-user -o jsonpath='{.data.password}' | base64 -d
#
# Requires: task port-forward:postgres (LB IP is firewalled; use kubectl port-forward)
DATABASE_URL=postgresql+asyncpg://kio_dev:CHANGE_ME@host.docker.internal:5432/kio_dev

# MQTT — hosted mosquitto LoadBalancer in the mosquitto namespace
MQTT_HOST=192.168.50.86
MQTT_PORT=1883
MQTT_TOPIC_PREFIX=kio/dev
